APP_ENV=development
PUBLIC_BASE_URL=http://localhost:8000

DATABASE_URL=postgresql+psycopg://reconstruction:reconstruction@postgres:5432/reconstruction
REDIS_URL=redis://redis:6379/0

STORAGE_BACKEND=s3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123456
S3_BUCKET=reconstruction
S3_SECURE=false
STORAGE_LOCAL_ROOT=/app/data/storage
HOST_IMPORT_ROOT=./samples
HOST_IMPORT_CONTAINER_ROOT=/host-imports
VITE_SAMPLE_PHOTO_PATH=/host-imports/ai_sample/pic
VITE_SAMPLE_VIDEO_PATH=/host-imports/good/south-building-good.mp4

ENGINE_CONFIG_PATH=/app/configs/engine.yaml
WORKSPACE_ROOT=/workspace
KEEP_FAILED_WORKSPACE=true
KEEP_PASSED_WORKSPACE=false

ADMIN_API_TOKEN=change-me-admin-token
INTERNAL_CONSOLE_API_TOKEN=change-me-console-token
EXTERNAL_SYSTEM_API_TOKEN=change-me-external-token
READ_ONLY_VIEWER_API_TOKEN=change-me-readonly-token

CELERY_TASK_ALWAYS_EAGER=false
WEBHOOK_TIMEOUT_SECONDS=10
ASSET_IMPORT_ROOTS=/host-imports
NERFSTUDIO_FAKE_RUNNER=false
NERFSTUDIO_DEFAULT_METHOD=splatfacto-big
NERFSTUDIO_HIGH_ITERATIONS=30000
NERFSTUDIO_SMOKE_ITERATIONS=20
NERFSTUDIO_VIDEO_FRAME_TARGET=500
